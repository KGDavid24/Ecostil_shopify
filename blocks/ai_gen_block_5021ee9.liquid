{% doc %}
  @prompt
    a slideshow section like what horizon currently has but only one difference, have an image for mobile and one independently fdor desktop for slides., if not heading and texts added and button for a slide, make the whole slide clickablșe and add an URL to configure on admin
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-slideshow-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-slideshow-slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.slide_height_desktop }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-slides-{{ ai_gen_id }} {
      height: {{ block.settings.slide_height_mobile }}px;
    }
  }

  .ai-slideshow-slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease-in-out, visibility 0.6s ease-in-out;
  }

  .ai-slideshow-slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .ai-slideshow-slide-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    text-decoration: none;
    color: inherit;
  }

  .ai-slideshow-slide-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-slideshow-slide-image-desktop-{{ ai_gen_id }} {
    display: block;
  }

  .ai-slideshow-slide-image-mobile-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-slide-image-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-slideshow-slide-image-mobile-{{ ai_gen_id }} {
      display: block;
    }
  }

  .ai-slideshow-slide-content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: {{ block.settings.content_vertical_alignment }};
    justify-content: {{ block.settings.content_horizontal_alignment }};
    padding: 40px;
    z-index: 2;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-slide-content-{{ ai_gen_id }} {
      padding: 20px;
    }
  }

  .ai-slideshow-slide-text-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-slideshow-slide-heading-{{ ai_gen_id }} {
    margin: 0 0 16px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-slide-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
      margin: 0 0 12px;
    }
  }

  .ai-slideshow-slide-text-{{ ai_gen_id }} {
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-slide-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
      margin: 0 0 16px;
    }
  }

  .ai-slideshow-slide-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: background-color 0.3s ease;
  }

  .ai-slideshow-slide-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-slideshow-controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 3;
  }

  .ai-slideshow-dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    cursor: pointer;
    border: none;
    padding: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-slideshow-dot-{{ ai_gen_id }}:hover {
    opacity: 0.8;
    transform: scale(1.2);
  }

  .ai-slideshow-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.3);
  }

  .ai-slideshow-arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .ai-slideshow-arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
    transform: translateY(-50%) scale(1.1);
  }

  .ai-slideshow-arrow-prev-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-slideshow-arrow-next-{{ ai_gen_id }} {
    right: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-arrow-{{ ai_gen_id }} {
      width: 36px;
      height: 36px;
    }

    .ai-slideshow-arrow-prev-{{ ai_gen_id }} {
      left: 10px;
    }

    .ai-slideshow-arrow-next-{{ ai_gen_id }} {
      right: 10px;
    }
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-slideshow-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }
{% endstyle %}

<slideshow-{{ ai_gen_id }} class="ai-slideshow-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-slideshow-container-{{ ai_gen_id }}">
    <div class="ai-slideshow-slides-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          assign slide_desktop_image_key = 'slide_' | append: i | append: '_desktop_image'
          assign slide_mobile_image_key = 'slide_' | append: i | append: '_mobile_image'
          assign slide_heading_key = 'slide_' | append: i | append: '_heading'
          assign slide_text_key = 'slide_' | append: i | append: '_text'
          assign slide_button_text_key = 'slide_' | append: i | append: '_button_text'
          assign slide_button_link_key = 'slide_' | append: i | append: '_button_link'
          assign slide_url_key = 'slide_' | append: i | append: '_url'

          assign slide_enabled = block.settings[slide_enabled_key]
          assign slide_desktop_image = block.settings[slide_desktop_image_key]
          assign slide_mobile_image = block.settings[slide_mobile_image_key]
          assign slide_heading = block.settings[slide_heading_key]
          assign slide_text = block.settings[slide_text_key]
          assign slide_button_text = block.settings[slide_button_text_key]
          assign slide_button_link = block.settings[slide_button_link_key]
          assign slide_url = block.settings[slide_url_key]

          assign has_content = false
          if slide_heading != blank or slide_text != blank or slide_button_text != blank
            assign has_content = true
          endif

          assign active_class = ''
          if forloop.first
            assign active_class = 'active'
          endif
        %}

        {% if slide_enabled %}
          <div class="ai-slideshow-slide-{{ ai_gen_id }} {{ active_class }}" data-slide-index="{{ forloop.index }}">
            {% if has_content == false and slide_url != blank %}
              <a href="{{ slide_url }}" class="ai-slideshow-slide-link-{{ ai_gen_id }}">
                {% if slide_desktop_image %}
                  <img
                    src="{{ slide_desktop_image | image_url: width: 2000 }}"
                    alt="{{ slide_desktop_image.alt | escape }}"
                    loading="lazy"
                    width="{{ slide_desktop_image.width }}"
                    height="{{ slide_desktop_image.height }}"
                    class="ai-slideshow-slide-image-{{ ai_gen_id }} ai-slideshow-slide-image-desktop-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-slideshow-placeholder-{{ ai_gen_id }} ai-slideshow-slide-image-desktop-{{ ai_gen_id }}">
                    {{ 'hero-apparel-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                {% if slide_mobile_image %}
                  <img
                    src="{{ slide_mobile_image | image_url: width: 1000 }}"
                    alt="{{ slide_mobile_image.alt | escape }}"
                    loading="lazy"
                    width="{{ slide_mobile_image.width }}"
                    height="{{ slide_mobile_image.height }}"
                    class="ai-slideshow-slide-image-{{ ai_gen_id }} ai-slideshow-slide-image-mobile-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-slideshow-placeholder-{{ ai_gen_id }} ai-slideshow-slide-image-mobile-{{ ai_gen_id }}">
                    {{ 'hero-apparel-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </a>
            {% else %}
              {% if slide_desktop_image %}
                <img
                  src="{{ slide_desktop_image | image_url: width: 2000 }}"
                  alt="{{ slide_desktop_image.alt | escape }}"
                  loading="lazy"
                  width="{{ slide_desktop_image.width }}"
                  height="{{ slide_desktop_image.height }}"
                  class="ai-slideshow-slide-image-{{ ai_gen_id }} ai-slideshow-slide-image-desktop-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-slideshow-placeholder-{{ ai_gen_id }} ai-slideshow-slide-image-desktop-{{ ai_gen_id }}">
                  {{ 'hero-apparel-1' | placeholder_svg_tag }}
                  {% if has_content == false %}
                    <div class="ai-slideshow-empty-state-{{ ai_gen_id }}">
                      Add images and content for slide {{ i }}
                    </div>
                  {% endif %}
                </div>
              {% endif %}

              {% if slide_mobile_image %}
                <img
                  src="{{ slide_mobile_image | image_url: width: 1000 }}"
                  alt="{{ slide_mobile_image.alt | escape }}"
                  loading="lazy"
                  width="{{ slide_mobile_image.width }}"
                  height="{{ slide_mobile_image.height }}"
                  class="ai-slideshow-slide-image-{{ ai_gen_id }} ai-slideshow-slide-image-mobile-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-slideshow-placeholder-{{ ai_gen_id }} ai-slideshow-slide-image-mobile-{{ ai_gen_id }}">
                  {{ 'hero-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if has_content %}
                <div class="ai-slideshow-slide-content-{{ ai_gen_id }}">
                  <div class="ai-slideshow-slide-text-wrapper-{{ ai_gen_id }}">
                    {% if slide_heading != blank %}
                      <h2 class="ai-slideshow-slide-heading-{{ ai_gen_id }}">{{ slide_heading }}</h2>
                    {% endif %}

                    {% if slide_text != blank %}
                      <div class="ai-slideshow-slide-text-{{ ai_gen_id }}">{{ slide_text }}</div>
                    {% endif %}

                    {% if slide_button_text != blank and slide_button_link != blank %}
                      <a href="{{ slide_button_link }}" class="ai-slideshow-slide-button-{{ ai_gen_id }}">
                        {{ slide_button_text }}
                      </a>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_arrows %}
      <button class="ai-slideshow-arrow-{{ ai_gen_id }} ai-slideshow-arrow-prev-{{ ai_gen_id }}" aria-label="Previous slide">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="ai-slideshow-arrow-{{ ai_gen_id }} ai-slideshow-arrow-next-{{ ai_gen_id }}" aria-label="Next slide">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-slideshow-controls-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
            assign slide_enabled = block.settings[slide_enabled_key]
          %}
          {% if slide_enabled %}
            <button
              class="ai-slideshow-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
              data-slide-index="{{ forloop.index }}"
              aria-label="Go to slide {{ forloop.index }}"
            ></button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class Slideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.dots = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-slideshow-slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-slideshow-dot-{{ ai_gen_id }}'));
        this.prevButton = this.querySelector('.ai-slideshow-arrow-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-slideshow-arrow-next-{{ ai_gen_id }}');

        this.setupEventListeners();
        this.startAutoplay();
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });
      }

      goToSlide(index) {
        this.slides[this.currentSlide].classList.remove('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.remove('active');
        }

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.add('active');
        }

        this.resetAutoplay();
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        const autoplayEnabled = {{ block.settings.autoplay | json }};
        const autoplaySpeed = {{ block.settings.autoplay_speed | times: 1000 }};

        if (autoplayEnabled && this.slides.length > 1) {
          this.autoplayInterval = setInterval(() => {
            this.nextSlide();
          }, autoplaySpeed);
        }
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resetAutoplay() {
        this.stopAutoplay();
        this.startAutoplay();
      }
    }

    customElements.define('slideshow-{{ ai_gen_id }}', Slideshow{{ ai_gen_id }});
  })();
</script>

