{% doc %}
  @prompt
    a slideshow section like what horizon currently has but only one difference, have an image for mobile and one independently for desktop for slides., if not heading and texts added and button for a slide, make the whole slide clickablșe and add an URL to configure on admin. the slide image should always try to adapt the width to the width of the device and the height auto, so that the i8nserted image always looks good, no stretching.
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-slideshow-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-slideshow-slides-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} {
    min-width: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-slideshow-slide-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    text-decoration: none;
    color: inherit;
  }

  .ai-slideshow-slide-content-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-slideshow-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
  }

  .ai-slideshow-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .ai-slideshow-image-desktop-{{ ai_gen_id }} {
    display: block;
  }

  .ai-slideshow-image-mobile-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-image-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-slideshow-image-mobile-{{ ai_gen_id }} {
      display: block;
    }
  }

  .ai-slideshow-text-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    width: 90%;
    max-width: 600px;
    z-index: 2;
  }

  .ai-slideshow-heading-{{ ai_gen_id }} {
    margin: 0 0 16px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
  }

  .ai-slideshow-text-{{ ai_gen_id }} {
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
  }

  .ai-slideshow-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: background-color 0.3s ease;
  }

  .ai-slideshow-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-slideshow-controls-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 0 20px;
    z-index: 3;
    pointer-events: none;
  }

  .ai-slideshow-arrow-{{ ai_gen_id }} {
    background-color: {{ block.settings.arrow_bg_color }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
    pointer-events: auto;
  }

  .ai-slideshow-arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_bg_color }};
  }

  .ai-slideshow-arrow-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-slideshow-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 3;
  }

  .ai-slideshow-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-slideshow-dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-slideshow-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-slideshow-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }

    .ai-slideshow-arrow-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-slideshow-arrow-{{ ai_gen_id }} svg {
      width: 20px;
      height: 20px;
    }
  }
{% endstyle %}

<slideshow-{{ ai_gen_id }} class="ai-slideshow-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-slideshow-container-{{ ai_gen_id }}">
    <div class="ai-slideshow-slides-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          assign desktop_image_key = 'slide_' | append: i | append: '_desktop_image'
          assign mobile_image_key = 'slide_' | append: i | append: '_mobile_image'
          assign heading_key = 'slide_' | append: i | append: '_heading'
          assign text_key = 'slide_' | append: i | append: '_text'
          assign button_text_key = 'slide_' | append: i | append: '_button_text'
          assign button_link_key = 'slide_' | append: i | append: '_button_link'
          assign slide_link_key = 'slide_' | append: i | append: '_slide_link'

          assign slide_enabled = block.settings[slide_enabled_key]
          assign desktop_image = block.settings[desktop_image_key]
          assign mobile_image = block.settings[mobile_image_key]
          assign heading = block.settings[heading_key]
          assign text = block.settings[text_key]
          assign button_text = block.settings[button_text_key]
          assign button_link = block.settings[button_link_key]
          assign slide_link = block.settings[slide_link_key]

          assign has_content = false
          if heading != blank or text != blank or button_text != blank
            assign has_content = true
          endif

          assign use_mobile_image = mobile_image
          unless use_mobile_image
            assign use_mobile_image = desktop_image
          endunless
        %}

        {% if slide_enabled %}
          <div class="ai-slideshow-slide-{{ ai_gen_id }}" data-slide="{{ i }}">
            {% if has_content == false and slide_link != blank %}
              <a href="{{ slide_link }}" class="ai-slideshow-slide-link-{{ ai_gen_id }}">
                <div class="ai-slideshow-slide-content-{{ ai_gen_id }}">
                  <div class="ai-slideshow-image-wrapper-{{ ai_gen_id }}">
                    {% if desktop_image %}
                      <img
                        src="{{ desktop_image | image_url: width: 2000 }}"
                        alt="{{ desktop_image.alt | escape }}"
                        loading="lazy"
                        width="{{ desktop_image.width }}"
                        height="{{ desktop_image.height }}"
                        class="ai-slideshow-image-{{ ai_gen_id }} ai-slideshow-image-desktop-{{ ai_gen_id }}"
                      >
                    {% else %}
                      <div class="ai-slideshow-placeholder-{{ ai_gen_id }} ai-slideshow-image-desktop-{{ ai_gen_id }}">
                        {{ 'hero-apparel-1' | placeholder_svg_tag }}
                        <div class="ai-slideshow-empty-state-{{ ai_gen_id }}">
                          Next, add a desktop image for slide {{ i }}
                        </div>
                      </div>
                    {% endif %}

                    {% if use_mobile_image %}
                      <img
                        src="{{ use_mobile_image | image_url: width: 1000 }}"
                        alt="{{ use_mobile_image.alt | escape }}"
                        loading="lazy"
                        width="{{ use_mobile_image.width }}"
                        height="{{ use_mobile_image.height }}"
                        class="ai-slideshow-image-{{ ai_gen_id }} ai-slideshow-image-mobile-{{ ai_gen_id }}"
                      >
                    {% else %}
                      <div class="ai-slideshow-placeholder-{{ ai_gen_id }} ai-slideshow-image-mobile-{{ ai_gen_id }}">
                        {{ 'hero-apparel-1' | placeholder_svg_tag }}
                        <div class="ai-slideshow-empty-state-{{ ai_gen_id }}">
                          Next, add a mobile image for slide {{ i }}
                        </div>
                      </div>
                    {% endif %}
                  </div>
                </div>
              </a>
            {% else %}
              <div class="ai-slideshow-slide-content-{{ ai_gen_id }}">
                <div class="ai-slideshow-image-wrapper-{{ ai_gen_id }}">
                  {% if desktop_image %}
                    <img
                      src="{{ desktop_image | image_url: width: 2000 }}"
                      alt="{{ desktop_image.alt | escape }}"
                      loading="lazy"
                      width="{{ desktop_image.width }}"
                      height="{{ desktop_image.height }}"
                      class="ai-slideshow-image-{{ ai_gen_id }} ai-slideshow-image-desktop-{{ ai_gen_id }}"
                    >
                  {% else %}
                    <div class="ai-slideshow-placeholder-{{ ai_gen_id }} ai-slideshow-image-desktop-{{ ai_gen_id }}">
                      {{ 'hero-apparel-1' | placeholder_svg_tag }}
                      <div class="ai-slideshow-empty-state-{{ ai_gen_id }}">
                        Next, add a desktop image for slide {{ i }}
                      </div>
                    </div>
                  {% endif %}

                  {% if use_mobile_image %}
                    <img
                      src="{{ use_mobile_image | image_url: width: 1000 }}"
                      alt="{{ use_mobile_image.alt | escape }}"
                      loading="lazy"
                      width="{{ use_mobile_image.width }}"
                      height="{{ use_mobile_image.height }}"
                      class="ai-slideshow-image-{{ ai_gen_id }} ai-slideshow-image-mobile-{{ ai_gen_id }}"
                    >
                  {% else %}
                    <div class="ai-slideshow-placeholder-{{ ai_gen_id }} ai-slideshow-image-mobile-{{ ai_gen_id }}">
                      {{ 'hero-apparel-1' | placeholder_svg_tag }}
                      <div class="ai-slideshow-empty-state-{{ ai_gen_id }}">
                        Next, add a mobile image for slide {{ i }}
                      </div>
                    </div>
                  {% endif %}
                </div>

                {% if has_content %}
                  <div class="ai-slideshow-text-overlay-{{ ai_gen_id }}">
                    {% if heading != blank %}
                      <h2 class="ai-slideshow-heading-{{ ai_gen_id }}">{{ heading }}</h2>
                    {% endif %}

                    {% if text != blank %}
                      <div class="ai-slideshow-text-{{ ai_gen_id }}">{{ text }}</div>
                    {% endif %}

                    {% if button_text != blank and button_link != blank %}
                      <a href="{{ button_link }}" class="ai-slideshow-button-{{ ai_gen_id }}">
                        {{ button_text }}
                      </a>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_arrows %}
      <div class="ai-slideshow-controls-{{ ai_gen_id }}">
        <button class="ai-slideshow-arrow-{{ ai_gen_id }} ai-slideshow-prev-{{ ai_gen_id }}" aria-label="Previous slide">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button class="ai-slideshow-arrow-{{ ai_gen_id }} ai-slideshow-next-{{ ai_gen_id }}" aria-label="Next slide">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-slideshow-dots-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class Slideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slidesContainer = this.querySelector('.ai-slideshow-slides-{{ ai_gen_id }}');
        this.slides = Array.from(this.querySelectorAll('.ai-slideshow-slide-{{ ai_gen_id }}'));
        this.prevButton = this.querySelector('.ai-slideshow-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-slideshow-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-slideshow-dots-{{ ai_gen_id }}');

        if (this.slides.length === 0) return;

        this.setupDots();
        this.setupEventListeners();
        this.showSlide(0);

        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      setupDots() {
        if (!this.dotsContainer) return;

        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-slideshow-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', 'Go to slide ' + (index + 1));
          dot.addEventListener('click', () => this.goToSlide(index));
          this.dotsContainer.appendChild(dot);
        });

        this.dots = Array.from(this.dotsContainer.querySelectorAll('.ai-slideshow-dot-{{ ai_gen_id }}'));
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          {% if block.settings.autoplay %}
            this.startAutoplay();
          {% endif %}
        });
      }

      showSlide(index) {
        this.currentSlide = index;
        const offset = -index * 100;
        this.slidesContainer.style.transform = `translateX(${offset}%)`;

        if (this.dots) {
          this.dots.forEach((dot, i) => {
            if (i === index) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });
        }
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      goToSlide(index) {
        this.showSlide(index);
        this.stopAutoplay();
        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('slideshow-{{ ai_gen_id }}', Slideshow{{ ai_gen_id }});
  })();
</script>

