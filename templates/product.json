    "custom_liquid_xwFA6r": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<!-- Product Description Section -->\n{% if product.description != blank %}\n  <style>\n    .product-description-section {\n      width: 100%;\n      margin: 50px 0;\n      font-family: \"Inter\", sans-serif;\n      color: #333;\n    }\n\n    .product-description-section h2 {\n      font-size: 24px;\n      font-weight: 600;\n      text-align: left;\n      margin-bottom: 20px;\n      color: #111;\n    }\n\n    .product-description-content {\n      font-size: 15px;\n      line-height: 1.6;\n      color: #555;\n    }\n\n    @media (max-width: 600px) {\n      .product-description-section h2 {\n        font-size: 20px;\n      }\n      .product-description-content {\n        font-size: 14px;\n      }\n    }\n  </style>\n\n  <div class=\"product-description-section\">\n    <h2>Descriere produs</h2>\n    <div class=\"product-description-content\">\n      {{ product.description }}\n    </div>\n  </div>\n{% endif %}",
        "color_scheme": "scheme-3",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "custom_liquid_X7NUhW": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<!-- Product Specifications Section (New Fields) -->\n{% assign specs = \n  \"categorie_principala,marime,culoare,material,tip_imbracaminte,pentru,sezon\" \n  | split: \",\" \n%}\n\n{% assign show_specs = false %}\n\n{% for field in specs %}\n  {% if product.metafields.custom[field] %}\n    {% assign show_specs = true %}\n    {% break %}\n  {% endif %}\n{% endfor %}\n\n{% if show_specs %}\n  <style>\n    .product-specs-section {\n      width: 100%;\n      margin: 50px 0;\n      font-family: \"Inter\", sans-serif;\n      color: #333;\n    }\n\n    .product-specs-section h2 {\n      font-size: 24px;\n      font-weight: 600;\n      text-align: left;\n      margin-bottom: 20px;\n      color: #111;\n    }\n\n    .product-specs-table {\n      width: 100%;\n      border-collapse: collapse;\n      font-size: 15px;\n    }\n\n    .product-specs-table tr {\n      border-bottom: 1px solid #e0e0e0;\n    }\n\n    .product-specs-table td {\n      padding: 10px 12px;\n      vertical-align: top;\n    }\n\n    .product-specs-table td:first-child {\n      font-weight: 600;\n      width: 35%;\n      color: #222;\n    }\n\n    .product-specs-table td:last-child {\n      color: #555;\n    }\n\n    @media (max-width: 600px) {\n      .product-specs-table td {\n        display: block;\n        width: 100%;\n        padding: 6px 0;\n      }\n      .product-specs-table td:first-child {\n        margin-top: 8px;\n      }\n      .product-specs-table tr {\n        border-bottom: none;\n        margin-bottom: 12px;\n        display: block;\n      }\n    }\n  </style>\n\n  <div class=\"product-specs-section\">\n    <h2>Specificații produs</h2>\n\n    <table class=\"product-specs-table\">\n      {% for field in specs %}\n        {% assign value = product.metafields.custom[field] %}\n        {% if value %}\n          <tr>\n            <td>\n              {% case field %}\n                {% when \"categorie_principala\" %} Categorie principală\n                {% when \"marime\" %} Mărime\n                {% when \"culoare\" %} Culoare\n                {% when \"material\" %} Material\n                {% when \"tip_imbracaminte\" %} Tip îmbrăcăminte\n                {% when \"pentru\" %} Pentru\n                {% when \"sezon\" %} Sezon\n                {% else %} {{ field | replace: \"_\", \" \" | capitalize }}\n              {% endcase %}\n            </td>\n            <td>{{ value.value }}</td>\n          </tr>\n        {% endif %}\n      {% endfor %}\n    </table>\n  </div>\n{% endif %}",
        "color_scheme": "scheme-3",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
